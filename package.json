### 2. src/index.ts
import express from 'express';
import { router as apiRouter } from './api/routes';
import { connectDatabase } from './db/schema';
import { initializeMCT } from './mct/server';
const app = express();
const PORT = process.env.PORT || 3000;
app.use(express.json());
app.use('/api', apiRouter);
app.listen(PORT, async () => {
  console.log(`Server running on port ${PORT}`);
  await connectDatabase();
  initializeMCT();
});
### 3. src/api/routes.ts
import { Router } from 'express';
import { listPods, createDeployment } from '../services/kubernetes';
export const router = Router();
router.get('/pods', async (req, res) => {
  const pods = await listPods();
  res.json(pods);
});
router.post('/deployments', async (req, res) => {
  const { name, image } = req.body;
  const deployment = await createDeployment(name, image);
  res.status(201).json(deployment);
});
### 4. src/db/schema.ts
import mongoose from 'mongoose';
export const connectDatabase = async () => {
  await mongoose.connect('mongodb://localhost/mct-kubernetes');
  console.log('Database connected');
};
const DeploymentSchema = new mongoose.Schema({
  name: String,
  image: String,
  replicas: { type: Number, default: 1 }
});
export const Deployment = mongoose.model('Deployment', DeploymentSchema);
### 5. src/mct/server.ts
